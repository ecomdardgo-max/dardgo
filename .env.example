# Shopify Storefront API credentials (loaded by Vite at build/dev time)
# This file is git-ignored via the `*.local` rule in .gitignore.
#
# Product reviews on the PDP (without Judge.me): expose metafields to Storefront
# (Admin → Settings → Custom data → Products). Standard: reviews.rating +
# reviews.rating_count. Optional JSON: namespace "custom", key "dardgo_reviews"
# (see src/lib/shopify-product-reviews.ts).
#
# Judge.me — stars widget (browser-safe public token). Shop domain defaults to VITE_SHOPIFY_STORE_DOMAIN.
# VITE_JUDGEME_PUBLIC_TOKEN=
# VITE_JUDGEME_SHOP_DOMAIN=dardgo-6404.myshopify.com
# VITE_JUDGEME_CDN_HOST=https://cdn.judge.me
#
# Judge.me → review text on PDP: sync to custom.dardgo_reviews (server script, not VITE_*):
#   JUDGEME_API_TOKEN=   (Private API token — Judge.me → Settings → Integrations → Developers)
#   npm run sync:judgeme-reviews
# Expose custom.dardgo_reviews to Storefront (Settings → Custom data → Products).
VITE_SHOPIFY_API_VERSION=2025-07
VITE_SHOPIFY_STORE_DOMAIN=dardgo-6404.myshopify.com
VITE_SHOPIFY_STOREFRONT_TOKEN=

# Public site URL (no trailing slash). Used when OAuth runs without a browser window (SSR);
# in the browser, redirect_uri / Origin use the current page origin instead.
# In Shopify: Headless → storefront → Customer Account API → Application setup:
#   Callback URL(s): https://your-domain/account/callback (exact string; same path as this app)
#   JavaScript origins: origin only, e.g. https://www.dardgo.in
# "redirect_uri mismatch" = that callback URL is missing or differs (www vs apex, trailing slash, wrong path).
# VITE_PUBLIC_APP_URL=https://www.dardgo.in
# Canonical headless storefront URL for sitemap.xml / robots.txt (Google Search Console). No trailing slash.
# SITE_URL=https://www.dardgo.in

# Shopify Customer Account API (Headless → Customer Account API → Public web app).
# Client ID is safe for browser use when you implement login / order history. Never put
# the client secret in a VITE_* variable (server-only). Docs: Shopify "Customer Account API".
# VITE_SHOPIFY_CUSTOMER_ACCOUNT_CLIENT_ID=
# Account page “Continue to sign in” → Shopify theme login (KwikPass / kp-account page)
# VITE_SHOPIFY_ACCOUNT_LOGIN_URL=https://dardgo-6404.myshopify.com/pages/kp-account

# Shiprocket Fastrr checkout (Shopify channel). Domain must match what Shiprocket saved for your store (no protocol), e.g. www.dardgo.in
# When set: loads fastrr UI assets + buyDirect for cart / drawer / PDP Buy now; falls back to Shopify checkout URL on error.
# VITE_SHIPROCKET_SELLER_DOMAIN=www.dardgo.in

# Meta (Facebook) Pixel — browser-safe ID for ads & conversion tracking (Events Manager).
# VITE_META_PIXEL_ID=2036567983884558

# Meta Conversions API (server-only — never use VITE_* prefix).
# Events Manager → your Pixel → Settings → Conversions API → Generate access token.
# META_PIXEL_ID=2036567983884558
# META_ACCESS_TOKEN=
# Optional: Events Manager → Test events → copy test code while validating.
# META_CAPI_TEST_EVENT_CODE=

# Shopify webhook signing secret (server-only).
# Shopify Admin → Settings → Notifications → Webhooks → create webhook → copy secret.
# Event: Order payment (orders/paid). URL: https://www.dardgo.in/api/shopify-orders-webhook
# SHOPIFY_WEBHOOK_SECRET=

# Shopify ADMIN API token — used by seed/sync scripts (npm run seed:shopify, sync:shopify-files).
# Create a Custom App in Shopify admin (Settings → Apps and sales channels →
# Develop apps), grant it write_products + read_products + read_files + write_publications,
# install it, then paste the token below in your local .env only (starts with `shpat_`). Never commit real tokens.
# For live PDP ingredient images from Content → Files, also add SHOPIFY_ADMIN_TOKEN on Vercel (server-only, not VITE_*).
SHOPIFY_ADMIN_TOKEN=
